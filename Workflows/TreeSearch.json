        "properties": {
          "code": "def draw(maze, order, title):\n    img = np.zeros_like(maze, dtype=float)\n\n    valid = order >= 0\n    if np.any(valid):\n        norm = order.astype(float)\n        norm[valid] /= norm[valid].max() + 1e-9\n\n        img[valid] = norm[valid]\n\n    img[maze == 1] = 0 # walls black\n\n    plt.figure(figsize=(7, 7))\n    plt.imshow(img, cmap=\"turbo\")\n    plt.title(title)\n    plt.xticks([])\n    plt.yticks([])\n    plt.show()\n\nmaze = generate_maze(25, 25)\nstart = (1, 1)\n",
