        "properties": {
          "code": "def generate_maze(n, m):\n    maze = np.ones((2*n+1, 2*m+1), dtype=int)\n    visited = np.zeros((n, m), dtype=bool)\n\n    def carve(x, y):\n        visited[x, y] = True\n        maze[2*x+1, 2*y+1] = 0\n\n        dirs = [(1,0), (-1,0), (0,1), (0,-1)]\n        random.shuffle(dirs)\n\n        for dx, dy in dirs:\n            nx, ny = x + dx, y + dy\n            if 0 <= nx < n and 0 <= ny < m and not visited[nx, ny]:\n                maze[2*x+1+dx, 2*y+1+dy] = 0\n                carve(nx, ny)\n    carve(0, 0)\n\n    for _ in range((n*m)//6):\n        x = random.randint(1, 2*n-1)\n        y = random.randint(1, 2*m-1)\n        if maze[x, y] == 1:\n            maze[x, y] = 0\n\n    return maze",
