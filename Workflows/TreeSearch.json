        "properties": {
          "code": "def bfs(maze, start):\n    h, w = maze.shape\n    q = deque([start])\n    seen = set([start])\n\n    order = -np.ones_like(maze, dtype=int)\n    t = 0\n\n    dirs = [(1,0), (-1,0), (0,1), (0,-1)]\n\n    while q:\n        x, y = q.popleft()\n\n        for dx, dy in dirs:\n            nx, ny = x + dx, y + dy\n\n            if 0 <= nx < h and 0 <= ny < w:\n                if maze[nx, ny] == 0 and (nx, ny) not in seen:\n                    seen.add((nx, ny))\n                    order[nx, ny] = t\n                    t += 1\n                    q.append((nx, ny))\n\n    order[start] = 0\n    return order",
          "vtab": {
