        "properties": {
          "code": "def dfs(maze, start):\n    h, w = maze.shape\n    stack = [start]\n    seen = set()\n\n    order = -np.ones_like(maze, dtype=int)\n    t = 0\n\n    dirs = [(1,0), (-1,0), (0,1), (0,-1)]\n\n    while stack:\n        x, y = stack.pop()\n\n        if (x, y) in seen:\n            continue\n\n        seen.add((x, y))\n        order[x, y] = t\n        t += 1\n\n        for dx, dy in reversed(dirs):\n            nx, ny = x + dx, y + dy\n            if 0 <= nx < h and 0 <= ny < w:\n                if maze[nx, ny] == 0 and (nx, ny) not in seen:\n                    stack.append((nx, ny))\n\n    return order\n",
          "vtab": {},
          "stdout": []
